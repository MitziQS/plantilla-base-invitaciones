  const barsWrap   = document.getElementById('progress-bars');
  const slides     = Array.from(document.querySelectorAll('.slide'));

  let current    = 0;
  let isPlaying  = false;
  let autoTimer  = null;
  let rafId      = null;
  let startTime  = null;

  // ── Build progress bars ──
  const tracks = [];
  const fills  = [];
  for (let i = 0; i < TOTAL; i++) {
    const t = document.createElement('div');
    t.className = 'pb-track';
    const f = document.createElement('div');
    f.className = 'pb-fill';
    t.appendChild(f);
    barsWrap.appendChild(t);
    tracks.push(t);
    fills.push(f);
  }

  // ── Start ──
  startBtn.addEventListener('click', () => {
    welcome.classList.add('fade-out');
    setTimeout(() => welcome.remove(), 950);
    goTo(0, null);
    startAutoAdvance();
    tryMusic();
    updateCountdown();
    setInterval(updateCountdown, 1000);
  });

  // ── Go to slide ──
  function goTo(idx, exitDir) {
    if (idx === current && slides[current].classList.contains('enter')) {
      // same slide, do nothing
    }
    // exit old
    if (slides[current].classList.contains('enter')) {
      slides[current].classList.remove('enter');
      slides[current].classList.add(exitDir === 'prev' ? 'exit-r' : 'exit-l');
      const old = slides[current];
      setTimeout(() => old.classList.remove('exit-l', 'exit-r'), 600);
    }
    current = ((idx % TOTAL) + TOTAL) % TOTAL;
    // reset animations by re-triggering
    slides[current].classList.remove('exit-l', 'exit-r', 'enter');
    void slides[current].offsetWidth; // force reflow
    slides[current].classList.add('enter');

    // progress bars
    fills.forEach((f, i) => {
      f.style.width = i < current ? '100%' : '0%';
    });
    counter.textContent = `${current + 1} / ${TOTAL}`;
  }

  // ── Auto advance with RAF for smooth bar ──
  function startAutoAdvance() {
    cancelAnimationFrame(rafId);
    clearTimeout(autoTimer);
    startTime = performance.now();

    function tick(now) {
      const elapsed = now - startTime;
      const pct = Math.min(100, (elapsed / DURATION) * 100);
      if (fills[current]) fills[current].style.width = pct + '%';
      if (elapsed < DURATION) {
        rafId = requestAnimationFrame(tick);
      }
    }
    rafId = requestAnimationFrame(tick);

    autoTimer = setTimeout(() => {
      goTo(current + 1, 'next');
      startAutoAdvance();
    }, DURATION);
  }

  function next() { goTo(current + 1, 'next'); startAutoAdvance(); }
  function prev() { goTo(current - 1, 'prev'); startAutoAdvance(); }

  // ── Keyboard ──
  document.addEventListener('keydown', e => {
    if (document.getElementById('welcome')) return;
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown')  next();
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')    prev();
  });

  // ── Touch swipe ──
  let tx = 0, ty = 0;
  document.addEventListener('touchstart', e => { tx = e.touches[0].clientX; ty = e.touches[0].clientY; }, { passive: true });
  document.addEventListener('touchend', e => {
    if (document.getElementById('welcome')) return;
    const dx = e.changedTouches[0].clientX - tx;
    const dy = e.changedTouches[0].clientY - ty;
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 45) {
      dx < 0 ? next() : prev();
    }
  }, { passive: true });

  // ── Click on sides (skip interactive elements) ──
  document.getElementById('slideshow').addEventListener('click', e => {
    if (document.getElementById('welcome')) return;
    if (e.target.closest('a, button, .map-btn, .rsvp-btn')) return;
    const x = e.clientX / window.innerWidth;
    if (x < 0.3) prev();
    else if (x > 0.7) next();
  });

  // ── Music ──
  function tryMusic() {
    audio.volume = 0.4;
    audio.play().then(() => {
      isPlaying = true;
      musicBtn.innerHTML = '♫';
      musicBtn.classList.add('playing');
    }).catch(() => { isPlaying = false; });
  }

  musicBtn.addEventListener('click', () => {
    if (isPlaying) {
      audio.pause();
      isPlaying = false;
      musicBtn.innerHTML = '🎵';
      musicBtn.classList.remove('playing');
    } else {
      audio.play();
      isPlaying = true;
      musicBtn.innerHTML = '♫';
      musicBtn.classList.add('playing');
    }
  });

  // ── Countdown ──
  function pad(n, w) { return String(n).padStart(w, '0'); }
  function updateCountdown() {
    const diff = WEDDING - Date.now();
    if (diff <= 0) {
      document.getElementById('cd-d').textContent = '¡Hoy!';
      ['cd-h','cd-m','cd-s'].forEach(id => { document.getElementById(id).textContent = '00'; });
      return;
    }
    document.getElementById('cd-d').textContent = pad(Math.floor(diff / 86400000), 3);
    document.getElementById('cd-h').textContent = pad(Math.floor((diff % 86400000) / 3600000), 2);
    document.getElementById('cd-m').textContent = pad(Math.floor((diff % 3600000) / 60000), 2);
    document.getElementById('cd-s').textContent = pad(Math.floor((diff % 60000) / 1000), 2);
  }
})();
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Panel de Invitaciones · Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300&family=Great+Vibes&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --cream: #F5EFE6; --cream-deep: #EDE0C8;
      --gold: #B08D57; --gold-light: #D4AF77; --gold-dark: #8B6B3D;
      --dark: #3D2E1F; --light: #E8DCC4;
      --border: rgba(176,141,87,.25);
      --white: #FDFAF6;
    }
    body { font-family:'Jost',sans-serif; background:#F0EAE0; color:var(--dark); min-height:100vh; }

    /* ── HEADER ── */
    .admin-hdr {
      background:var(--dark); color:var(--cream);
      padding:1.2rem 2rem; display:flex; align-items:center;
      justify-content:space-between; position:sticky; top:0; z-index:200;
      box-shadow:0 2px 24px rgba(0,0,0,.3);
    }
    .hdr-left { display:flex; align-items:center; gap:1rem; }
    .hdr-script { font-family:'Great Vibes',cursive; font-size:2rem; color:var(--gold-light); line-height:1; }
    .hdr-title { font-family:'Cormorant Garamond',serif; font-size:1.15rem; letter-spacing:.08em; }
    .hdr-sub { font-size:.58rem; letter-spacing:.35em; text-transform:uppercase; opacity:.45; margin-top:.15rem; }
    .hdr-badge { font-size:.58rem; letter-spacing:.3em; text-transform:uppercase; opacity:.35; }

    /* ── LAYOUT ── */
    .wrap { max-width:880px; margin:0 auto; padding:2rem 1.5rem 5rem; }

    /* ── SECTION CARD ── */
    .card { background:var(--white); border:1px solid var(--border); margin-bottom:1.4rem; overflow:hidden; }
    .card-hdr {
      background:linear-gradient(90deg, var(--dark) 0%, #5a4530 100%);
      color:var(--light); padding:.9rem 1.4rem;
      display:flex; align-items:center; gap:.8rem;
    }
    .card-num {
      width:26px; height:26px; border-radius:50%;
      background:var(--gold); color:var(--cream);
      display:flex; align-items:center; justify-content:center;
      font-size:.7rem; font-weight:500; flex-shrink:0;
    }
    .card-title { font-family:'Cormorant Garamond',serif; font-size:1.15rem; font-weight:400; }
    .card-body { padding:1.4rem; }

    /* ── FORM ELEMENTS ── */
    .row  { display:grid; grid-template-columns:1fr 1fr;  gap:1rem; margin-bottom:1rem; }
    .row3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:1rem; margin-bottom:1rem; }
    .row1 { display:grid; grid-template-columns:1fr; gap:1rem; margin-bottom:1rem; }
    @media(max-width:600px){ .row,.row3{ grid-template-columns:1fr; } }
    .fg { display:flex; flex-direction:column; gap:.35rem; }
    label { font-size:.62rem; letter-spacing:.3em; text-transform:uppercase; color:var(--gold-dark); font-weight:500; }
    input[type=text], input[type=date], input[type=time], input[type=url],
    input[type=number], select, textarea {
      font-family:'Jost',sans-serif; font-size:.87rem; font-weight:300;
      color:var(--dark); background:var(--cream); border:1px solid var(--border);
      padding:.62rem .9rem; outline:none; transition:border-color .25s; width:100%;
    }
    input:focus, select:focus, textarea:focus { border-color:var(--gold); }
    textarea { resize:vertical; min-height:70px; }
    .span2 { grid-column:span 2; }
    @media(max-width:600px){ .span2{ grid-column:span 1; } }

    /* ── SECTION LABEL ── */
    .sub-label {
      font-size:.62rem; letter-spacing:.32em; text-transform:uppercase;
      color:var(--gold); margin:1.2rem 0 .8rem; font-weight:500;
    }
    .sub-label:first-child { margin-top:0; }

    /* ── FILE DROP ── */
    .drop-zone {
      border:2px dashed var(--border); padding:2.2rem 1.5rem;
      text-align:center; cursor:pointer; position:relative;
      transition:border-color .25s, background .25s;
    }
    .drop-zone:hover, .drop-zone.over { border-color:var(--gold); background:rgba(176,141,87,.04); }
    .drop-zone input { position:absolute; inset:0; opacity:0; cursor:pointer; width:100%; height:100%; }
    .drop-icon { font-size:2.2rem; margin-bottom:.6rem; }
    .drop-text { font-size:.8rem; color:var(--dark); opacity:.6; }
    .drop-hint { font-size:.65rem; letter-spacing:.2em; color:var(--gold); margin-top:.3rem; }
    #media-preview { margin-top:1rem; display:none; }
    #media-preview img, #media-preview video { max-height:180px; max-width:100%; display:block; margin:0 auto; border:1px solid var(--border); }
    .media-meta { text-align:center; font-size:.68rem; color:var(--gold); margin-top:.5rem; letter-spacing:.15em; }
    .warn-box { background:rgba(160,70,0,.07); border:1px solid rgba(160,70,0,.2); color:#954500; font-size:.72rem; padding:.6rem .9rem; margin-top:.5rem; display:none; }
    .btn-sm { background:none; border:1px solid var(--border); color:var(--gold-dark); font-family:'Jost',sans-serif; font-size:.65rem; font-weight:400; letter-spacing:.25em; text-transform:uppercase; padding:.5rem 1rem; cursor:pointer; transition:all .25s; margin-top:.7rem; }
    .btn-sm:hover { background:rgba(176,141,87,.1); border-color:var(--gold); }

    /* ── SCHEDULE ── */
    #sched-list { list-style:none; margin-bottom:.8rem; }
    .si { display:flex; align-items:center; gap:.6rem; padding:.45rem 0; border-bottom:1px solid var(--border); }
    .si:last-child { border:none; }
    .si input[type=time] { max-width:100px; flex-shrink:0; }
    .si input[type=text] { flex:1; }
    .btn-rm { background:none; border:1px solid rgba(176,141,87,.3); color:var(--gold); width:26px; height:26px; cursor:pointer; font-size:1rem; line-height:1; flex-shrink:0; transition:all .2s; }
    .btn-rm:hover { background:rgba(176,141,87,.12); }
    .btn-add { background:none; border:1px solid var(--gold); color:var(--gold-dark); font-family:'Jost',sans-serif; font-size:.68rem; font-weight:500; letter-spacing:.28em; text-transform:uppercase; padding:.55rem 1.1rem; cursor:pointer; transition:all .25s; }
    .btn-add:hover { background:var(--gold); color:var(--cream); }

    /* ── ACCORDION ── */
    .acc-toggle {
      width:100%; background:rgba(176,141,87,.07); border:1px solid var(--border);
      border-bottom:none; color:var(--gold-dark); font-family:'Jost',sans-serif;
      font-size:.68rem; font-weight:500; letter-spacing:.25em; text-transform:uppercase;
      padding:.75rem 1rem; cursor:pointer; text-align:left; display:flex;
      align-items:center; justify-content:space-between; transition:background .25s;
    }
    .acc-toggle:hover { background:rgba(176,141,87,.14); }
    .acc-body { display:none; padding:1.2rem; background:var(--cream); border:1px solid var(--border); }
    .acc-body.open { display:block; }
    .code-wrap { background:#1a110a; color:#d4af77; font-family:'Courier New',monospace; font-size:.72rem; padding:1rem; overflow-x:auto; white-space:pre; position:relative; margin:1rem 0; border-radius:0; }
    .btn-copy { position:absolute; top:.5rem; right:.5rem; background:var(--gold); color:var(--cream); border:none; font-family:'Jost',sans-serif; font-size:.58rem; letter-spacing:.2em; text-transform:uppercase; padding:.35rem .7rem; cursor:pointer; }
    .steps { list-style:none; counter-reset:s; }
    .steps li { counter-increment:s; display:flex; gap:.8rem; align-items:flex-start; padding:.45rem 0; font-size:.8rem; opacity:.8; }
    .steps li::before { content:counter(s); min-width:20px; height:20px; border-radius:50%; background:var(--gold); color:var(--cream); display:flex; align-items:center; justify-content:center; font-size:.62rem; font-weight:500; flex-shrink:0; }

    /* ── QR ── */
    #qr-output { display:none; text-align:center; padding:1.5rem; background:var(--cream); border:1px solid var(--border); margin-top:.8rem; }
    #qr-canvas { display:inline-block; }
    #qr-canvas img { border:8px solid white; }
    .qr-label { font-size:.65rem; letter-spacing:.25em; text-transform:uppercase; color:var(--gold); margin:1rem 0 .8rem; }

    /* ── INFO BOX ── */
    .info { background:rgba(176,141,87,.07); border-left:3px solid var(--gold); padding:.75rem 1rem; font-size:.77rem; opacity:.8; margin-bottom:1rem; }

    /* ── GENERATE BTN ── */
    .gen-btn {
      display:block; width:100%; background:linear-gradient(90deg,var(--dark),#5a4530);
      color:var(--light); font-family:'Jost',sans-serif; font-size:.82rem; font-weight:500;
      letter-spacing:.4em; text-transform:uppercase; padding:1.3rem 2rem; border:none;
      cursor:pointer; transition:opacity .3s; margin-top:.5rem;
    }
    .gen-btn:hover { opacity:.85; }

    /* ── TOAST ── */
    .toast { position:fixed; bottom:2rem; left:50%; transform:translateX(-50%) translateY(100px); background:var(--dark); color:var(--gold-light); font-family:'Jost',sans-serif; font-size:.75rem; letter-spacing:.2em; text-transform:uppercase; padding:1rem 2rem; z-index:999; transition:transform .4s ease; box-shadow:0 4px 20px rgba(0,0,0,.3); pointer-events:none; }
    .toast.show { transform:translateX(-50%) translateY(0); }

    /* divider line */
    hr.soft { border:none; border-top:1px solid var(--border); margin:1.2rem 0; }
  </style>
</head>
<body>

<header class="admin-hdr">
  <div class="hdr-left">
    <div class="hdr-script">Invitaciones</div>
    <div>
      <div class="hdr-title">Panel de Administración</div>
      <div class="hdr-sub">Generador de invitaciones digitales</div>
    </div>
  </div>
  <div class="hdr-badge">Admin v2.0</div>
</header>

<div class="wrap">

  <!-- ── 1. EVENTO ── -->
  <div class="card">
    <div class="card-hdr"><div class="card-num">1</div><div class="card-title">Datos del evento</div></div>
    <div class="card-body">
      <div class="row">
        <div class="fg"><label>Nombre protagonista 1</label><input type="text" id="name1" placeholder="Sofía" value="Sofía"></div>
        <div class="fg"><label>Nombre protagonista 2</label><input type="text" id="name2" placeholder="Mateo" value="Mateo"></div>
      </div>
      <div class="row">
        <div class="fg">
          <label>Tipo de evento</label>
          <select id="eventType">
            <option value="boda">Boda</option>
            <option value="xv">XV Años</option>
            <option value="cumple">Cumpleaños</option>
            <option value="bautizo">Bautizo</option>
            <option value="graduacion">Graduación</option>
          </select>
        </div>
        <div class="fg"><label>Fecha del evento</label><input type="date" id="eventDate" value="2026-02-14"></div>
      </div>
      <div class="row">
        <div class="fg"><label>Hora de la ceremonia</label><input type="time" id="cerTime" value="17:00"></div>
        <div class="fg"><label>Código de vestimenta</label><input type="text" id="dresscode" value="Formal de Noche"></div>
      </div>
      <div class="row">
        <div class="fg"><label>Descripción caballeros</label><input type="text" id="dcMen" value="Smoking o traje formal oscuro"></div>
        <div class="fg"><label>Descripción damas</label><input type="text" id="dcWomen" value="Vestido largo o cóctel elegante"></div>
      </div>
    </div>
  </div>

  <!-- ── 2. FAMILIAS ── -->
  <div class="card">
    <div class="card-hdr"><div class="card-num">2</div><div class="card-title">Familias</div></div>
    <div class="card-body">
      <div class="row">
        <div class="fg"><label>Nombre familia 1</label><input type="text" id="fam1" value="Familia Ramírez Vega"></div>
        <div class="fg"><label>Padres / tutores 1</label><input type="text" id="parents1" value="Eduardo Ramírez &amp; Carmen Vega de Ramírez"></div>
      </div>
      <div class="row">
        <div class="fg"><label>Nombre familia 2</label><input type="text" id="fam2" value="Familia Torres Morales"></div>
        <div class="fg"><label>Padres / tutores 2</label><input type="text" id="parents2" value="Alejandro Torres &amp; Lucía Morales de Torres"></div>
      </div>
      <div class="row">
        <div class="fg"><label>Rol familia 1</label><input type="text" id="role1" value="Padres de la novia" placeholder="Padres de la novia"></div>
        <div class="fg"><label>Rol familia 2</label><input type="text" id="role2" value="Padres del novio" placeholder="Padres del novio"></div>
      </div>
    </div>
  </div>

  <!-- ── 3. FOTO / VIDEO ── -->
  <div class="card">
    <div class="card-hdr"><div class="card-num">3</div><div class="card-title">Foto o Video (slide especial)</div></div>
    <div class="card-body">
      <div class="info">Se agrega un slide de pantalla completa entre la portada y las familias. Para video se recomienda &lt;15 MB y ≤12 segundos.</div>
      <div class="drop-zone" id="drop-zone">
        <input type="file" id="mediaFile" accept="image/*,video/*">
        <div class="drop-icon">🌸</div>
        <div class="drop-text">Arrastra tu foto o video aquí, o haz clic para seleccionar</div>
        <div class="drop-hint">JPG · PNG · MP4 · MOV</div>
      </div>
      <div id="media-preview">
        <div id="media-content"></div>
        <div class="media-meta" id="media-meta"></div>
        <div class="warn-box" id="media-warn"></div>
        <button class="btn-sm" onclick="clearMedia()">✕ Quitar archivo</button>
      </div>
    </div>
  </div>

  <!-- ── 4. LUGARES ── -->
  <div class="card">
    <div class="card-hdr"><div class="card-num">4</div><div class="card-title">Lugares</div></div>
    <div class="card-body">
      <p class="sub-label">Ceremonia</p>
      <div class="row">
        <div class="fg"><label>Nombre del lugar</label><input type="text" id="cerName" value="Parroquia de San Francisco"></div>
        <div class="fg"><label>Dirección</label><input type="text" id="cerAddr" value="Av. Madero 7, Centro Histórico, CDMX"></div>
      </div>
      <div class="row1">
        <div class="fg"><label>Link Google Maps (ceremonia)</label><input type="url" id="cerMaps" value="https://maps.google.com/?q=Parroquia+de+San+Francisco+CDMX"></div>
      </div>

      <hr class="soft">
      <p class="sub-label">Recepción</p>
      <div class="row">
        <div class="fg"><label>Hora recepción</label><input type="time" id="recTime" value="19:00"></div>
        <div class="fg"><label>Nombre del lugar</label><input type="text" id="recName" value="Hacienda Los Jardines"></div>
      </div>
      <div class="row">
        <div class="fg"><label>Dirección</label><input type="text" id="recAddr" value="Carretera Tlalpan km 12.5, CDMX"></div>
        <div class="fg"><label>Link Google Maps (recepción)</label><input type="url" id="recMaps" value="https://maps.google.com/?q=Hacienda+Los+Jardines+Tlalpan+CDMX"></div>
      </div>
    </div>
  </div>

  <!-- ── 5. PROGRAMA ── -->
  <div class="card">
    <div class="card-hdr"><div class="card-num">5</div><div class="card-title">Programa del día</div></div>
    <div class="card-body">
      <ul id="sched-list"></ul>
      <button class="btn-add" onclick="addSchedItem()">+ Agregar horario</button>
    </div>
  </div>

  <!-- ── 6. REGALOS ── -->
  <div class="card">
    <div class="card-hdr"><div class="card-num">6</div><div class="card-title">Mesa de regalos</div></div>
    <div class="card-body">
      <div class="row">
        <div class="fg"><label>Tienda / Etiqueta</label><input type="text" id="g1label" value="Liverpool"></div>
        <div class="fg"><label>Número de evento</label><input type="text" id="g1val" value="# 52847391"></div>
      </div>
      <hr class="soft">
      <div class="row3">
        <div class="fg"><label>Banco</label><input type="text" id="g2bank" value="BBVA"></div>
        <div class="fg"><label>Titular</label><input type="text" id="g2name" value="Sofía Ramírez"></div>
        <div class="fg"><label>CLABE / Cuenta</label><input type="text" id="g2clabe" value="1234 5678 9012 3456 78"></div>
      </div>
    </div>
  </div>

  <!-- ── 7. RSVP ── -->
  <div class="card">
    <div class="card-hdr"><div class="card-num">7</div><div class="card-title">RSVP — Google Sheets</div></div>
    <div class="card-body">
      <div class="row">
        <div class="fg"><label>Fecha límite de confirmación</label><input type="date" id="rsvpDate" value="2026-01-15"></div>
        <div class="fg"><label>URL Google Apps Script</label><input type="url" id="scriptURL" placeholder="https://script.google.com/macros/s/..."></div>
      </div>

      <!-- Instructions accordion -->
      <button class="acc-toggle" onclick="toggleAcc(this)">
        <span>📋 Cómo conectar con Google Sheets (paso a paso)</span><span>▾</span>
      </button>
      <div class="acc-body">
        <ol class="steps">
          <li>Ve a <a href="https://sheets.new" target="_blank" style="color:var(--gold-dark)">sheets.new</a> y crea una hoja nueva en blanco.</li>
          <li>En el menú: <strong>Extensiones → Apps Script</strong>.</li>
          <li>Borra el código existente y pega este:</li>
        </ol>
        <div class="code-wrap" id="script-code">function doPost(e) {
  try {
    var sheet = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
    if (sheet.getLastRow() === 0) {
      sheet.appendRow(['Fecha', 'Nombre', 'Personas', 'Restricciones', 'Mensaje']);
      sheet.getRange(1,1,1,5).setFontWeight('bold');
    }
    var d = JSON.parse(e.postData.contents);
    sheet.appendRow([
      new Date().toLocaleString('es-MX', {timeZone:'America/Mexico_City'}),
      d.nombre || '', d.personas || '',
      d.restricciones || '', d.mensaje || ''
    ]);
    return ContentService
      .createTextOutput(JSON.stringify({status:'ok'}))
      .setMimeType(ContentService.MimeType.JSON);
  } catch(err) {
    return ContentService
      .createTextOutput(JSON.stringify({status:'error',msg:err.toString()}))
      .setMimeType(ContentService.MimeType.JSON);
  }
}<button class="btn-copy" onclick="copyScript()">Copiar</button></div>
        <ol class="steps" style="counter-reset:s 3">
          <li>Guarda con <strong>Ctrl + S</strong>.</li>
          <li>Clic en <strong>Implementar → Nueva implementación</strong>.</li>
          <li>Tipo: <em>Aplicación web</em> · Ejecutar como: <em>Yo</em> · Acceso: <em>Cualquier persona</em>.</li>
          <li>Clic en <strong>Implementar</strong> → autoriza los permisos.</li>
          <li>Copia la <strong>URL de la aplicación web</strong> y pégala arriba en este panel.</li>
        </ol>
      </div>
    </div>
  </div>

  <!-- ── 8. QR ── -->
  <div class="card">
    <div class="card-hdr"><div class="card-num">8</div><div class="card-title">Código QR imprimible</div></div>
    <div class="card-body">
      <div class="info">Sube primero la invitación generada a internet (Google Drive público, Netlify, etc.) y pega aquí la URL para generar el QR.</div>
      <div class="row">
        <div class="fg"><label>URL pública de la invitación</label><input type="url" id="invURL" placeholder="https://tudominio.com/sofia-mateo.html"></div>
        <div class="fg" style="justify-content:flex-end"><button class="btn-add" onclick="makeQR()" style="height:38px;align-self:flex-end">Generar QR</button></div>
      </div>
      <div id="qr-output">
        <div id="qr-canvas"></div>
        <div class="qr-label">QR listo para imprimir</div>
        <button class="btn-add" onclick="dlQR()">⬇ Descargar QR (PNG)</button>
      </div>
    </div>
  </div>

  <!-- ── GENERATE ── -->
  <button class="gen-btn" onclick="generate()">✦ &nbsp; Generar y Descargar Invitación &nbsp; ✦</button>

</div><!-- .wrap -->

<div class="toast" id="toast"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
/* ════════════════════════════════════════════
   ADMIN PANEL LOGIC
════════════════════════════════════════════ */

// ── Media state ──
let mediaB64 = '';
let mediaType = ''; // 'image' | 'video'

// ── Schedule defaults ──
const defaultSched = [
  ['17:00','Ceremonia religiosa'],
  ['18:00','Cóctel de bienvenida'],
  ['19:00','Cena'],
  ['20:30','Primer baile de los novios'],
  ['21:00','Corte del pastel'],
  ['21:30','¡Fiesta!'],
  ['01:00','Despedida']
];
(function initSched() { defaultSched.forEach(s => addSchedItem(s[0], s[1])); })();

function addSchedItem(t='', ev='') {
  const li = document.createElement('li');
  li.className = 'si';
  li.innerHTML =
    '<input type="time" value="' + t + '">' +
    '<input type="text" value="' + ev + '" placeholder="Descripción del evento">' +
    '<button class="btn-rm" onclick="this.parentElement.remove()" title="Eliminar">×</button>';
  document.getElementById('sched-list').appendChild(li);
}

function getSchedule() {
  return Array.from(document.querySelectorAll('#sched-list .si')).map(li => ({
    time: li.querySelector('input[type=time]').value,
    event: li.querySelector('input[type=text]').value
  })).filter(s => s.time && s.event);
}

// ── Media upload ──
document.getElementById('mediaFile').addEventListener('change', function() {
  const f = this.files[0]; if (!f) return;
  const isVid = f.type.startsWith('video/');
  const isImg = f.type.startsWith('image/');
  if (!isVid && !isImg) { alert('Por favor selecciona una imagen o video.'); return; }
  mediaType = isVid ? 'video' : 'image';
  const sizeMB = f.size / 1048576;
  const reader = new FileReader();
  reader.onload = e => {
    mediaB64 = e.target.result;
    const preview = document.getElementById('media-preview');
    const content = document.getElementById('media-content');
    const meta    = document.getElementById('media-meta');
    const warn    = document.getElementById('media-warn');
    preview.style.display = 'block';
    content.innerHTML = isVid
      ? '<video src="' + e.target.result + '" controls muted style="max-height:180px;max-width:100%"></video>'
      : '<img src="' + e.target.result + '" style="max-height:180px;max-width:100%">';
    meta.textContent = f.name + ' · ' + sizeMB.toFixed(1) + ' MB';
    if (sizeMB > 15) {
      warn.style.display = 'block';
      warn.textContent = '⚠ Archivo grande (' + sizeMB.toFixed(1) + ' MB). El HTML puede pesar +20 MB. Considera comprimir el video.';
    } else { warn.style.display = 'none'; }
  };
  reader.readAsDataURL(f);
});

// Drag & drop
const dz = document.getElementById('drop-zone');
dz.addEventListener('dragover', e => { e.preventDefault(); dz.classList.add('over'); });
dz.addEventListener('dragleave', () => dz.classList.remove('over'));
dz.addEventListener('drop', e => {
  e.preventDefault(); dz.classList.remove('over');
  const f = e.dataTransfer.files[0];
  if (f) { const dt = new DataTransfer(); dt.items.add(f); document.getElementById('mediaFile').files = dt.files; document.getElementById('mediaFile').dispatchEvent(new Event('change')); }
});

function clearMedia() {
  mediaB64 = ''; mediaType = '';
  document.getElementById('media-preview').style.display = 'none';
  document.getElementById('media-content').innerHTML = '';
  document.getElementById('mediaFile').value = '';
}

// ── Accordion ──
function toggleAcc(btn) {
  const body = btn.nextElementSibling;
  body.classList.toggle('open');
  btn.lastElementChild.textContent = body.classList.contains('open') ? '▴' : '▾';
}

// ── Copy script ──
function copyScript() {
  const txt = document.getElementById('script-code').innerText.replace('Copiar','').trim();
  navigator.clipboard.writeText(txt).then(() => toast('✦ Código copiado'));
}

// ── QR ──
let qrObj = null;
function makeQR() {
  const url = document.getElementById('invURL').value.trim();
  if (!url) { alert('Ingresa la URL de la invitación primero.'); return; }
  const canvas = document.getElementById('qr-canvas');
  canvas.innerHTML = '';
  qrObj = new QRCode(canvas, { text:url, width:200, height:200, colorDark:'#3D2E1F', colorLight:'#F5EFE6', correctLevel: QRCode.CorrectLevel.H });
  document.getElementById('qr-output').style.display = 'block';
}
function dlQR() {
  const img = document.querySelector('#qr-canvas img');
  if (!img) return;
  const a = document.createElement('a'); a.href = img.src; a.download = 'qr-invitacion.png'; a.click();
}

// ── Toast ──
function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

// ── Date format ──
function fmtDate(iso) {
  const meses = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
  const [y,m,d] = iso.split('-');
  return parseInt(d) + ' de ' + meses[parseInt(m)-1].charAt(0).toUpperCase() + meses[parseInt(m)-1].slice(1) + ' de ' + y;
}

